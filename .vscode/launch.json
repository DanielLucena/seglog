{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        // UDP configurations
        {
            "type": "java",
            "name": "gateway udp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.GatewayMain",
            "projectName": "seglog",
            "console": "integratedTerminal",
            "args": [
                "udp",
                "gateway",
                "9000",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "writer udp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.LogWritterMain",
            "projectName": "seglog",
            "args": [
                "udp",
                "logwriter",
                "9001",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "reader udp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.LogReaderMain",
            "projectName": "seglog",
            "args": [
                "udp",
                "logreader",
                "9002",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "testing udp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.TestingClientMain",
            "projectName": "seglog",
            "args": [
                "udp",
                "testing-client",
                "9003",
                "--config=settings.json"
            ]
        },
        // TCP configurations
        {
            "type": "java",
            "name": "gateway tcp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.GatewayMain",
            "projectName": "seglog",
            "args": [
                "tcp",
                "gateway",
                "9000",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "writer tcp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.LogWritterMain",
            "projectName": "seglog",
            "args": [
                "tcp",
                "logwriter",
                "9001",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "reader tcp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.LogReaderMain",
            "projectName": "seglog",
            "args": [
                "tcp",
                "logreader",
                "9002",
                "--config=settings.json"
            ]
        },
        {
            "type": "java",
            "name": "testing tcp",
            "request": "launch",
            "mainClass": "br.dev.danielrl.TestingClientMain",
            "projectName": "seglog",
            "args": [
                "tcp",
                "testing-client",
                "9003",
                "--config=settings.json"
            ]
        }
    ],
    "compounds": [
        {
            "name": "udp all (gateway+writer+reader+testing)",
            "configurations": [
                "gateway udp",
                "writer udp",
                "reader udp",
                "testing udp"
            ],
            "stopAll": true
        },
        {
            "name": "tcp all (gateway+writer+reader+testing)",
            "configurations": [
                "gateway tcp",
                "writer tcp",
                "reader tcp",
                "testing tcp"
            ],
            "stopAll": true
        }
    ]
}